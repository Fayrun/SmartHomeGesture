<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 Smart Home Gesture"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Điều khiển thiết bị thông minh bằng cử chỉ"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ── Gesture Feedback ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/layoutGestureFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/accent_purple">

            <TextView
                android:id="@+id/tvGestureStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👋 Thực hiện cử chỉ để điều khiển..."
                android:textColor="@color/white"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="16dp" />
        </androidx.cardview.widget.CardView>

        <!-- ── Camera Wave Detector ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCameraWave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/card_bg"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📷 Vẫy tay qua camera"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCameraStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● Đang chạy"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Preview nhỏ camera trước -->
                <androidx.camera.view.PreviewView
                    android:id="@+id/cameraPreviewView"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="fitCenter"
                    app:scaleType="fillCenter" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✋ Vẫy tay 2 lần trước camera để bật/tắt đèn"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:paddingTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Thiết bị mục tiêu ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎯 Thiết bị điều khiển"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerTargetDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/spinner_bg" />

                <TextView
                    android:id="@+id/tvTargetDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tất cả thiết bị"
                    android:textColor="@color/accent_blue"
                    android:textSize="13sp"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Âm lượng hiện tại ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔊 Âm lượng (nghiêng điện thoại)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVolumeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50%"
                        android:textColor="@color/accent_green"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressVolume"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:progress="50"
                    android:max="100"
                    android:progressTint="@color/accent_green" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Sensor Data ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Accelerometer -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/card_bg">

                <TextView
                    android:id="@+id/tvAccelData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="Accelerometer\nX: 0.00\nY: 0.00\nZ: 0.00\n|a|: 0.00"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </androidx.cardview.widget.CardView>

            <!-- Gyroscope -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/card_bg">

                <TextView
                    android:id="@+id/tvGyroData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="Gyroscope\nX: 0.00\nY: 0.00\nZ: 0.00"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ── Hướng dẫn cử chỉ ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📖 Hướng dẫn cử chỉ"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProxStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👁 Proximity: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✋  Vẫy tay trước camera  →  Bật/Tắt đèn\n📱  Nghiêng lên                →  Tăng âm lượng\n📱  Nghiêng xuống           →  Giảm âm lượng\n🔄  Xoay sang phải          →  Bài tiếp theo\n🔄  Xoay sang trái           →  Bài trước"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 Vẫy tay 2 lần qua cảm biến nhỏ cạnh camera trước"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:paddingTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Nút điều hướng ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnScanBluetooth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="🔵 BT"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnToggleCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:text="📷 Camera"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnManageDevices"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="⚙️ Thiết bị"
                android:backgroundTint="@color/accent_purple"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- ── Danh sách thiết bị ── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡 Danh sách thiết bị IoT"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDevices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="500dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
